rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
       return request.auth != null && (request.auth.token.email == 'vadimtchepikov@gmail.com' || request.auth.token.email == 'goatcaca111@gmail.com');
    }

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
