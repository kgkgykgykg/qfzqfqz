{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account configuration, subscription details and device security logs.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User email address login identifier."
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "avatar": {
          "type": "string"
        },
        "subscription": {
          "type": "string",
          "enum": [
            "starter",
            "pro",
            "business",
            null
          ]
        },
        "passwordHidden": {
          "type": "string"
        },
        "created_ip": {
          "type": "string",
          "description": "The initial registration IP address."
        },
        "authorized_ips": {
          "type": "array",
          "description": "A list of trusted IP addresses who bypass secondary OTP checks."
        },
        "isAdmin": {
          "type": "boolean"
        },
        "session_lock_id": {
          "type": "string"
        },
        "isBanned": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "number"
        },
        "userAgent": {
          "type": "string"
        },
        "referredByLink": {
          "type": "string"
        }
      },
      "required": [
        "email",
        "passwordHidden"
      ]
    },
    "OtpCredentials": {
      "title": "OtpCredentials",
      "description": "Temporary 6-digit passwordless sign-in validation codes.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "expiresAt": {
          "type": "number"
        },
        "ip": {
          "type": "string"
        },
        "timestamps": {
          "type": "array"
        }
      },
      "required": [
        "email",
        "code",
        "expiresAt"
      ]
    },
    "AdminSettings": {
      "title": "AdminSettings",
      "description": "Global admin settings like maintenance mode",
      "type": "object",
      "properties": {
        "maintenanceMode": {
          "type": "boolean"
        },
        "maintenanceMessage": {
          "type": "string"
        }
      },
      "required": [
        "maintenanceMode"
      ]
    },
    "AffiliateLink": {
      "title": "AffiliateLink",
      "description": "Affiliate links generated by users",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "shortCode": {
          "type": "string"
        },
        "createdAt": {
          "type": "number"
        }
      },
      "required": [
        "userId",
        "shortCode",
        "createdAt"
      ]
    },
    "AffiliateClick": {
      "title": "AffiliateClick",
      "description": "Clicks on affiliate links",
      "type": "object",
      "properties": {
        "linkId": {
          "type": "string"
        },
        "ip": {
          "type": "string"
        },
        "userAgent": {
          "type": "string"
        },
        "clickedAt": {
          "type": "number"
        }
      },
      "required": [
        "linkId",
        "clickedAt",
        "ip",
        "userAgent"
      ]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Root collections mapping user profiles."
    },
    "/otps/{email}": {
      "schema": "OtpCredentials",
      "description": "Dynamic single-use temporary passwordless validation collection."
    },
    "/admin/settings": {
      "schema": "AdminSettings",
      "description": "Global settings"
    },
    "/affiliateLinks/{linkId}": {
      "schema": "AffiliateLink",
      "description": "User affiliate links"
    },
    "/affiliateClicks/{clickId}": {
      "schema": "AffiliateClick",
      "description": "Clicks on affiliate links"
    }
  }
}